# --- API ---
PORT=4000
DATABASE_URL=postgres://jtm:jtm@127.0.0.1:5432/jtm
NODE_ENV=development

# Money / locale
DEFAULT_CURRENCY=KES
DEFAULT_TAX_REGION=KE

# Billing
DUNNING_MAX_ATTEMPTS=3
INVOICE_GRACE_DAYS=5

# Auth — set AUTH_ENABLED=true to enforce JWT + RBAC (default off = demo mode)
AUTH_ENABLED=false
JWT_SECRET=change-me-to-a-long-random-string
JWT_TTL_HOURS=12
OTP_TTL_MINUTES=5
OTP_MAX_ATTEMPTS=5

# Payments — M-Pesa Daraja (sandbox values; leave blank to run in simulation mode)
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=
MPESA_CALLBACK_URL=http://localhost:4000/api/payments/mpesa/callback

# Payments — Stripe (leave blank to run in simulation mode)
STRIPE_SECRET_KEY=

# WhatsApp — Meta Cloud API (leave blank to log instead of send)
WA_PHONE_NUMBER_ID=
WA_ACCESS_TOKEN=

# Branding / storage / network
BRAND_NAME=JTM Networks
STORAGE_DIR=./storage
NETWORK_DRIVER=log   # 'log' (safe default) or 'mikrotik' (RouterOS command planner)

# --- Web ---
NEXT_PUBLIC_API_URL=http://localhost:4000
