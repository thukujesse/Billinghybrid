# Baked into the client bundle at build time (Next.js inlines NEXT_PUBLIC_*).
# This is only the FALLBACK API base for non-platform hosts (Render previews,
# dev tunnels, raw IP). Real *.hubnetwifi.co.ke hosts call their own origin
# (see web/lib/api.ts getBase) so Host->tenant routing works.
NEXT_PUBLIC_API_URL=https://demo.hubnetwifi.co.ke
